# Compilation Environment Configuration
# You can set custom C and C++ flags here
# export CFLAGS="-O3 -march=native"
# export CXXFLAGS="-O3 -march=native"

# Sunshine CMake configuration flags
SUNSHINE_CMAKE_FLAGS=(
  "-DCMAKE_C_COMPILER=gcc"
  "-DCMAKE_CXX_COMPILER=g++"
  "-DSUNSHINE_ENABLE_CUDA=OFF"
  "-DSUNSHINE_ENABLE_X11=ON"
  "-DSUNSHINE_ENABLE_KWIN=OFF"
  "-DSUNSHINE_ENABLE_WAYLAND=ON"
  "-DSUNSHINE_BUILD_WAYLAND=ON"
  "-DSUNSHINE_ENABLE_VULKAN=ON"
  "-DSUNSHINE_ENABLE_DRM=ON"
  "-DSUNSHINE_ENABLE_TRAY=0"
  "-DBUILD_DOCS=OFF"
  "-DCMAKE_BUILD_TYPE=Release"
  "-DSUNSHINE_BUILD_HOMEBREW=OFF"
  "-DCMAKE_PREFIX_PATH=/usr"
  "-DFFMPEG_PREPARED_BINARIES=/ffmpeg-dist/ffmpeg"
  "-DGLAD_SKIP_PIP_INSTALL=ON"
  "-G" "Ninja"
)

# Build-deps CMake configuration flags
BUILD_DEPS_CMAKE_FLAGS=(
  "-DCMAKE_INSTALL_PREFIX=/ffmpeg-dist"
  "-DCMAKE_BUILD_TYPE=Release"
  "-DBUILD_FFMPEG_NV_CODEC_HEADERS=OFF"
  "-DBUILD_FFMPEG_AMF=OFF"
  "-G" "Ninja"
)